{
  "name": "okay-karaoke-studio",
  "version": "0.1.0",
  "private": true,
  "description": "A desktop karaoke lyric timing and production studio.",
  "author": "Okay Karaoke Studio",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "main": "electron/main.cjs",
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24",
    "bun": ">=1.3.14"
  },
  "scripts": {
    "icons": "electron scripts/generate-icon-assets.cjs",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "format": "bun scripts/format-diff.mjs --write",
    "format:check": "bun scripts/format-diff.mjs --check",
    "format:all": "prettier . --write --ignore-unknown",
    "format:all:check": "prettier . --check --ignore-unknown",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:image": "electron scripts/image-decoder-smoke.cjs",
    "test:visual": "node scripts/video-style-visual-smoke.cjs",
    "test:watch": "vitest",
    "test:video": "electron scripts/video-export-smoke.cjs",
    "dist": "bun run build && electron-builder",
    "dist:dir": "bun run build && electron-builder --dir"
  },
  "dependencies": {
    "lucide-react": "1.24.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "10.0.3",
    "diff": "9.0.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "happy-dom": "20.8.3",
    "prettier": "3.9.5",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wait-on": "9.0.10"
  },
  "build": {
    "appId": "studio.okay.karaoke",
    "productName": "Okay Karaoke Studio",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "scripts/visual-result-validation.cjs",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "electronFuses": {
      "resetAdHocDarwinSignature": true,
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "loadBrowserProcessSpecificV8Snapshot": false,
      "grantFileProtocolExtraPrivileges": false
    },
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Okay Karaoke Studio"
    }
  }
}
